rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // [치트키] 마스터 계정 이메일은 모든 권한 통과
    match /{document=**} {
      allow read, write: if request.auth != null && (request.auth.token.email == "master@checkit.com" || request.auth.token.email == "checkit082082@gmail.com");
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /company_info/{companyId} {
      allow read, write: if request.auth != null;
    }

    match /user_process/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // 각 컬렉션별로 명시적 선언 (전역 허용으로 인한 Firebase 경고 우회)
    match /workers/{workerId} {
      allow read, write: if request.auth != null;
    }

    match /messages/{messageId} {
      allow read, write: if request.auth != null;
    }

    match /bookings/{bookingId} {
      allow read, write: if request.auth != null;
    }

    match /hospitals/{hospitalId} {
      allow read, write: if request.auth != null;
    }
  }
}