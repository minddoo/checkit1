rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is a Master Admin
    function isMaster() {
      return request.auth != null && (
        request.auth.token.email == 'master@checkit.com' ||
        request.auth.token.email == 'checkit082082@gmail.com' ||
        request.auth.token.email == 'checkit082@gmail.com'
      );
    }
    
    // Check if the user is accessing their own document
    function isOwner(email) {
      return request.auth != null && request.auth.token.email == email;
    }

    // 1. User Documents (Users Collection)
    match /users/{email} {
      // Masters can read/write all users. Users can only read/write their own document.
      allow read, write: if isMaster() || isOwner(email);
    }

    // 2. Consultation States
    match /user_chat_states/{email} {
      allow read, write: if isMaster() || isOwner(email);
    }

    // 3. User Activations
    match /user_activations/{email} {
      allow read, write: if isMaster() || isOwner(email);
    }

    // 4. Default rule: Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
