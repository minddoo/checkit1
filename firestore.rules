rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function getUserCompany() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId;
    }

    match /user_process/{userId} {

      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      allow read: if request.auth != null
                  && getUserRole() == "company_admin"
                  && resource.data.companyId == getUserCompany();

      allow read, write: if request.auth != null
                         && getUserRole() == "super_admin";
                         
      // Allow access to messages subcollection
      match /messages/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read, write: if request.auth != null && getUserRole() == "super_admin";
      }
    }
    
    match /contact_inquiries/{inquiryId} {
      allow create: if true; // Public can submit inquiries
      allow read, write: if request.auth != null && getUserRole() == "super_admin";
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, write: if request.auth != null && getUserRole() == "super_admin";
    }

    match /{document=**} {
      allow read, write: if request.auth != null
                         && getUserRole() == "super_admin";
    }
  }
}