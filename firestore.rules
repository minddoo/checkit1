rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is a Master Admin
    function isMaster() {
      return request.auth != null && (
        request.auth.token.email == 'master@checkit.com' ||
        request.auth.token.email == 'checkit082082@gmail.com' ||
        request.auth.token.email == 'checkit082@gmail.com'
      );
    }
    
    // Check if the user is accessing their own document by email
    function isOwnerByEmail(email) {
      return request.auth != null && request.auth.token.email == email;
    }

    // Check if the user is accessing their own document by uid
    function isOwnerByUid(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // 1. User Documents (Users Collection)
    // Document ID can be UID or Email depending on how it was created
    match /users/{docId} {
      allow read: if isMaster() || isOwnerByUid(docId) || isOwnerByEmail(docId) || (request.auth != null && resource.data.email == request.auth.token.email) || (request.auth != null && resource.data.uid == request.auth.uid);
      allow write: if isMaster() || isOwnerByUid(docId) || isOwnerByEmail(docId);
    }

    // 2. Consultation States (Document ID is usually Email)
    match /user_chat_states/{docId} {
      allow read, write: if isMaster() || isOwnerByEmail(docId) || isOwnerByUid(docId) || (request.auth != null && resource.data.email == request.auth.token.email);
    }

    // 3. User Activations (Document ID is usually Email)
    match /user_activations/{docId} {
      allow read, write: if isMaster() || isOwnerByEmail(docId) || isOwnerByUid(docId) || (request.auth != null && resource.data.email == request.auth.token.email);
    }

    
    // 5. Scheduled Notifications
    match /scheduled_notifications/{docId} {
      allow read, write: if true;
    }
    // 4. Default rule: Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
