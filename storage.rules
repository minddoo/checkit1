rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /user_files/{userId}/{allPaths=**} {
      // Users can manage their own files
      // Admins can manage all user files
      allow read, write: if request.auth != null && (request.auth.uid == userId || 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "super_admin");
    }
    
    match /translated_results/{userId}/{allPaths=**} {
      // Managers upload translations
      // Users can only read their own translations
      allow read: if request.auth != null && (request.auth.uid == userId || 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "super_admin");
      allow write: if request.auth != null && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "super_admin";
    }
  }
}